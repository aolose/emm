{
	"name": "emm",
	"version": "0.0.1",
	"private": true,
	"prepare": "svelte-kit sync",
	"author": "Aolose",
	"license": "MIT",
	"scripts": {
		"test": "bun test tests/lib/server/blogExp.test.ts",
		"dev": "bun --bun run vite dev",
		"build": "bun --bun run vite build",
		"preview": "bun --bun vite preview",
		"check": "bun --bun svelte-kit sync && bun svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "bun --bun svelte-kit sync && bun svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "bun eslint --fix . && bun prettier --check .",
		"syncReadme": "bun scripts/readme.js",
		"format": "bun prettier --write ."
	},
	"devDependencies": {
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@sveltejs/kit": "^2.59.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/bun": "^1.3.14",
		"@types/html-to-text": "^9.0.4",
		"@types/marked": "^6.0.0",
		"@types/node": "^25.7.0",
		"@typescript-eslint/eslint-plugin": "^8.59.3",
		"@typescript-eslint/parser": "^8.59.3",
		"eslint": "^10.3.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.1",
		"globals": "^17.6.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.2",
		"sass": "^1.99.0",
		"svelte": "^5.55.5",
		"svelte-adapter-bun": "^1.0.1",
		"svelte-check": "^4.4.8",
		"svelte-preprocess": "^6.0.3",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.3",
		"vite": "^8.0.12"
	},
	"type": "module",
	"dependencies": {
		"clipboard": "^2.0.11",
		"clsx": "^2.1.1",
		"compressorjs": "^1.3.0",
		"diff-match-patch-typescript": "^1.1.3",
		"easymde": "^2.21.0",
		"highlight.js": "^11.11.1",
		"html-to-text": "^10.0.0",
		"ip-matching": "^2.1.2",
		"isbot": "^5.1.40",
		"marked": "^18.0.3",
