{
	"name": "emm",
	"version": "0.0.1",
	"private": true,
	"prepare": "svelte-kit sync",
	"author": "Aolose",
	"license": "MIT",
	"scripts": {
		"test": "bun test tests/lib/server/blogExp.test.ts",
		"test:e2e": "bun run tests/e2e/turnstile-browser.ts",
		"test:e2e:setup": "bun run tests/e2e/helpers/setup.ts",
		"test:pw": "bun run tests/e2e/playwright/setup-db.ts && playwright test",
		"test:pw:ui": "playwright test --ui",
		"test:pw:headed": "playwright test --headed",
		"dev": "bun --bun run vite dev",
		"build": "bun --bun run vite build",
		"preview": "bun --bun vite preview",
		"check": "bun --bun svelte-kit sync && bun svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "bun --bun svelte-kit sync && bun svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "bun eslint --fix . && bun prettier --check .",
		"syncReadme": "bun scripts/readme.js",
		"format": "bun prettier --write ."
	},
	"devDependencies": {
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.60.0",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/bun": "^1.3.14",
		"@types/html-to-text": "^9.0.4",
		"@types/marked": "^6.0.0",
		"@types/node": "^25.9.1",
		"@typescript-eslint/eslint-plugin": "^8.60.1",
		"@typescript-eslint/parser": "^8.60.1",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"sass": "^1.100.0",
		"svelte": "^5.56.1",
		"svelte-adapter-bun": "^1.0.1",
		"svelte-check": "^4.5.0",
		"svelte-preprocess": "^6.0.5",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1",
		"vite": "^8.0.16"
	},
	"type": "module",
	"dependencies": {
		"@codemirror/lang-markdown": "^6.5.0",
		"clipboard": "^2.0.11",
		"clsx": "^2.1.1",
		"codemirror": "^6.0.2",
		"compressorjs": "^1.3.0",
		"diff-match-patch-typescript": "^1.1.3",
		"fflate": "^0.8.3",
		"highlight.js": "^11.11.1",
		"html-to-text": "^10.0.0",
		"ip-matching": "^2.1.2",
		"ip2location-nodejs": "^9.8.0",
		"isbot": "^5.1.40",
		"marked": "^18.0.4",
		"morphdom": "^2.7.8",
		"svelte-codemirror-editor": "^2.1.0",
		"tiny-pinyin": "^1.3.2",
		"turndown": "^7.2.4",
		"turndown-plugin-gfm": "^1.0.2",
		"upload": "^1.3.2",
		"viewerjs": "^1.11.7"
	}
}
